---
---
<section class="relative h-[600px] flex items-center justify-center text-center text-white">
  
  <div class="absolute inset-0 bg-black/60 z-10"></div>
  
  <img 
    src="https://images.unsplash.com/photo-1513104890138-7c749659a591?q=80&w=2070&auto=format&fit=crop" 
    alt="Pizza deliciosa de fondo" 
    class="absolute inset-0 w-full h-full object-cover z-0"
  />

  <div class="relative z-20 container mx-auto px-4">
    <span class="text-charly-red font-bold text-xl md:text-2xl tracking-widest uppercase mb-4 block">
      Auténtico Sabor
    </span>
    <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
      Menos Espera, <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-charly-red to-orange-500">
        Más Pizza
      </span>
    </h1>
    <p class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto text-gray-200">
      Ingredientes frescos, masa hecha a mano y el secreto de la casa en cada rebanada.
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="#menu" class="bg-charly-red text-white px-8 py-4 rounded-full font-bold text-lg hover:scale-105 transition transform shadow-lg hover:shadow-red-900/50">
        Ver Menú
      </a>
      <a href="#promos" class="bg-white text-charly-black px-8 py-4 rounded-full font-bold text-lg hover:bg-gray-200 transition">
        Promociones
      </a>
    </div>
  </div>
</section>