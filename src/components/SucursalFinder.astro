

<section id="ubicaciones" class="py-24 bg-gray-50 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <h2 class="text-4xl font-extrabold text-charly-black mb-2 tracking-tight">
        Localiza tu <span class="text-charly-red">Charly Pizza</span>
      </h2>
      <p class="text-gray-500">Ingresa tu C.P. para buscar sucursales (Modo Demo).</p>
    </div>

    <div class="max-w-lg mx-auto relative group z-20">
      <div class="absolute -inset-1 bg-gradient-to-r from-charly-red to-orange-600 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-300"></div>
      
      <div class="relative bg-white rounded-full p-2 shadow-xl flex items-center ring-1 ring-gray-200">
        <input 
          type="text" 
          id="cp-input" 
          placeholder="Ej: 56600" 
          class="flex-grow p-4 bg-transparent outline-none text-gray-700 font-semibold placeholder-gray-400 ml-2"
          maxlength="5"
        />
        <button 
          id="btn-buscar"
          class="bg-charly-black text-white px-8 py-4 rounded-full font-bold shadow-lg hover:bg-charly-red transition-all duration-300 flex items-center gap-2"
        >
          <span id="btn-text">Buscar</span>
          <svg id="btn-loader" class="animate-spin h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </div>
    </div>

    <div id="resultados-container" class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center min-h-[300px]">
      <div class="col-span-full text-center opacity-60">
        <div class="bg-gray-200 w-24 h-24 rounded-full mx-auto mb-4 flex items-center justify-center text-4xl">📍</div>
        <p class="text-gray-400">Esperando código postal...</p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('btn-buscar');
      const btnText = document.getElementById('btn-text');
      const btnLoader = document.getElementById('btn-loader');
      const input = document.getElementById('cp-input');
      const container = document.getElementById('resultados-container');

      function simularBusqueda() {
        const cpIngresado = input.value.trim();
        if (cpIngresado.length < 4) return;

        // Animación de carga
        btn.disabled = true;
        btnText.textContent = "Buscando...";
        btnLoader.classList.remove('hidden');
        container.innerHTML = `
          <div class="col-span-full flex gap-6 justify-center w-full animate-pulse">
             <div class="h-48 w-full md:w-80 bg-gray-200 rounded-3xl"></div>
             <div class="h-48 w-80 bg-gray-200 rounded-3xl hidden md:block"></div>
          </div>
        `;

        // Simulamos el tiempo de respuesta de un servidor
        setTimeout(() => {
            btn.disabled = false;
            btnText.textContent = "Buscar";
            btnLoader.classList.add('hidden');

            // Mensaje de demostración para el portafolio
            container.innerHTML = `
                <div class="col-span-full text-center py-10 fade-in-up">
                    <div class="bg-orange-50 w-20 h-20 rounded-full mx-auto mb-4 flex items-center justify-center text-4xl">🍕</div>
                    <h3 class="text-2xl font-bold text-gray-800 mb-2">¡Versión de Demostración!</h3>
                    <p class="text-gray-500 max-w-md mx-auto">
                        Esta es una maqueta estática para GitHub.
                    </p>
                </div>
            `;
        }, 1500);
      }

      btn.addEventListener('click', simularBusqueda);
      input.addEventListener('keypress', (e) => { if(e.key === 'Enter') simularBusqueda() });
  });
</script>

<style>
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
</style>